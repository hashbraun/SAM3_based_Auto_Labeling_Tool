TEXT_PROMPT = "person . dog"

def detect_objects(image_path):

    image_source, image = load_image(image_path)

    boxes, logits, phrases = predict(
        model=grounding_model,
        image=image,
        caption=TEXT_PROMPT,
        box_threshold=0.35,
        text_threshold=0.25
    )

    h, w, _ = image_source.shape

    detections = []

    for box, phrase in zip(boxes, phrases):

        cx, cy, bw, bh = box

        x1 = int((cx - bw/2) * w)
        y1 = int((cy - bh/2) * h)
        x2 = int((cx + bw/2) * w)
        y2 = int((cy + bh/2) * h)

        detections.append({
            "class": phrase,
            "bbox": [x1, y1, x2, y2]
        })

    return detections


# -----------------------------
# SAM segmentation
# -----------------------------

def segment(image, detections):

    predictor.set_image(image)

    results = []

    for det in detections:

        x1, y1, x2, y2 = det["bbox"]

        box = np.array([[x1, y1, x2, y2]])

        masks, scores, logits = predictor.predict(
            box=box,
            multimask_output=True
        )

        best = np.argmax(scores)

        mask = masks[best]
        mask_logits = logits[best, :, :]

        results.append({
            "class": det["class"],
            "mask": mask,
            "mask_logits": mask_logits # Add logits to the result
        })

    return results


# -----------------------------
# 마스크 병합
# -----------------------------

def merge_masks(results):

    merged = {}

    for r in results:

        cls = r["class"]

        if cls not in merged:
            merged[cls] = []

        merged[cls].append(r["mask"])

    final = {}

    for cls, masks in merged.items():

        combined = np.zeros_like(masks[0])

        for m in masks:
            combined |= m

        final[cls] = combined

    return final


