# -----------------------------
# Interactive Correction
# -----------------------------
# Usage (in Colab cell):
#   %matplotlib widget
#   corrector = InteractiveCorrector("path/to/image.jpg", detections[0])
#   corrector.run()
#   # Left click  → positive point (green)
#   # Right click → negative point (red)
#   # After editing:
#   corrector.export_yolo("yolo_segment_output/labels/image.txt")

class InteractiveCorrector:

    def __init__(self, image_path, detection):
        """
        image_path  : path to the image file
        detection   : one detection dict {"class": str, "bbox": [x1,y1,x2,y2]}
        """
        self.image_path = image_path
        self.detection = detection

        image_bgr = cv2.imread(image_path)
        self.image = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2RGB)
        self.h, self.w = self.image.shape[:2]

        self.coords = []   # [[x, y], ...]
        self.labels = []   # [1 or 0, ...]
        self.mask = None
        self.prev_logits = None  # (1, 256, 256) logits for iterative refinement

        # Compute initial mask from bbox
        predictor.set_image(self.image)
        x1, y1, x2, y2 = detection["bbox"]
        box = np.array([[x1, y1, x2, y2]])
        masks, scores, logits = predictor.predict(box=box, multimask_output=True)
        best = int(np.argmax(scores))
        self.mask = masks[best]
        self.prev_logits = logits[best][np.newaxis]  # (1, 256, 256)

        self.fig, self.ax = plt.subplots(figsize=(10, 8))
        self.fig.canvas.mpl_connect("button_press_event", self._on_click)

    def _on_click(self, event):
        if event.inaxes is not self.ax:
            return
        if event.xdata is None or event.ydata is None:
            return

        x, y = int(event.xdata), int(event.ydata)

        if event.button == 1:        # left click → positive
            self.coords.append([x, y])
            self.labels.append(1)
            print(f"+ positive point ({x}, {y})")
        elif event.button == 3:      # right click → negative
            self.coords.append([x, y])
            self.labels.append(0)
            print(f"- negative point ({x}, {y})")
        else:
            return

        self._update_mask()
        self._redraw()

    def _update_mask(self):
        masks, scores, logits = predictor.predict(
            point_coords=np.array(self.coords),
            point_labels=np.array(self.labels),
            mask_input=self.prev_logits,
            multimask_output=True
        )
        best = int(np.argmax(scores))
        self.mask = masks[best]
        self.prev_logits = logits[best][np.newaxis]  # (1, 256, 256)

    def _redraw(self):
        self.ax.cla()
        overlay = self.image.copy()
        if self.mask is not None:
            overlay[self.mask] = (
                overlay[self.mask] * 0.4 + np.array([0, 255, 0]) * 0.6
            ).astype(np.uint8)
        self.ax.imshow(overlay)
        self.ax.set_title(
            f"class: {self.detection['class']} | "
            f"points: {len(self.coords)} "
            f"(+{self.labels.count(1)} / -{self.labels.count(0)})"
        )

        for (x, y), label in zip(self.coords, self.labels):
            color = "lime" if label == 1 else "red"
            marker = "+" if label == 1 else "x"
            self.ax.plot(x, y, marker=marker, color=color, markersize=12, markeredgewidth=2)

        self.ax.axis("off")
        self.fig.canvas.draw()

    def export_yolo(self, out_path):
        """Export refined mask to YOLO Segment 1.0 format (.txt)."""
        if self.mask is None:
            print("No mask to export.")
            return

        class_name = self.detection["class"]
        class_id = CLASS_MAP.get(class_name)
        if class_id is None:
            print(f"Warning: '{class_name}' not in CLASS_MAP. Cannot export.")
            return

        yolo_polygons = mask_to_yolo_segment(self.mask, self.w, self.h)
        lines = []
        for poly in yolo_polygons:
            if poly:
                lines.append(f"{class_id} " + " ".join(f"{v:.6f}" for v in poly))

        if not lines:
            print("No valid polygons found in mask.")
            return

        os.makedirs(os.path.dirname(out_path) if os.path.dirname(out_path) else ".", exist_ok=True)
        with open(out_path, "w") as f:
            f.write("\n".join(lines))
        print(f"Exported refined mask → {out_path}  ({len(lines)} polygon(s))")

    def run(self):
        """Display the interactive correction UI."""
        self._redraw()
        plt.tight_layout()
        plt.show()
        print("Ready. Left click = positive  |  Right click = negative")