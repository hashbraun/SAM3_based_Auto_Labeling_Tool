import os
import cv2
import numpy as np
from pathlib import Path

# Define output directories
OUTPUT_DIR = "yolo_segment_output"
OUTPUT_IMAGES_DIR = os.path.join(OUTPUT_DIR, "images")
OUTPUT_LABELS_DIR = os.path.join(OUTPUT_DIR, "labels")

os.makedirs(OUTPUT_IMAGES_DIR, exist_ok=True)
os.makedirs(OUTPUT_LABELS_DIR, exist_ok=True)

# Class mapping (assuming 'person' and 'dog' are the only detected classes for now)
CLASS_MAP = {
    "person": 0,
    "dog": 1
}

def mask_to_yolo_segment(mask, image_width, image_height):
    # Convert mask to uint8 for findContours
    mask_uint8 = mask.astype(np.uint8) * 255

    # Find contours
    # cv2.RETR_EXTERNAL: Retrieves only the extreme outer contours.
    # cv2.CHAIN_APPROX_SIMPLE: Compresses horizontal, vertical, and diagonal segments and leaves only their end points.
    contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    yolo_polygons = []
    for contour in contours:
        # Reshape contour to (N, 2)
        polygon = contour.reshape(-1, 2)

        # Normalize coordinates
        normalized_polygon = []
        for x, y in polygon:
            normalized_polygon.append(x / image_width)
            normalized_polygon.append(y / image_height)

        yolo_polygons.append(normalized_polygon)

    return yolo_polygons

def export_to_yolo_segment_format(image_path, output_images_dir, output_labels_dir):
    image_name = Path(image_path).name
    base_name = Path(image_path).stem

    # Load image
    image_bgr = cv2.imread(image_path)
    if image_bgr is None:
        print(f"Warning: Could not load image {image_path}. Skipping.")
        return

    image_rgb = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2RGB)
    h, w, _ = image_rgb.shape

    # Perform detection (using the global detect_objects function)
    detections = detect_objects(image_path)

    if not detections:
        print(f"No objects detected for {image_name}. Skipping export.")
        return

    # Perform segmentation for each detected object
    # The segment function returns a list of dicts, each with 'class', 'mask', 'mask_logits'
    segmentation_results = segment(image_rgb, detections)

    label_lines = []
    for seg_res in segmentation_results:
        obj_class_name = seg_res["class"]
        mask = seg_res["mask"]

        class_id = CLASS_MAP.get(obj_class_name)
        if class_id is None:
            print(f"Warning: Class '{obj_class_name}' not in CLASS_MAP. Skipping mask for this class in {image_name}.")
            continue

        # Convert mask to YOLO polygon format
        yolo_polygons = mask_to_yolo_segment(mask, w, h)

        for poly in yolo_polygons:
            if poly: # Ensure polygon is not empty
                # Format: class_id x1 y1 x2 y2 ... xn yn
                line = f"{class_id} " + " ".join(map(str, poly))
                label_lines.append(line)

    if label_lines:
        # Save original image to the images folder
        cv2.imwrite(os.path.join(output_images_dir, image_name), image_bgr)

        # Save label file to the labels folder
        label_file_path = os.path.join(output_labels_dir, f"{base_name}.txt")
        with open(label_file_path, "w") as f:
            f.write("\n".join(label_lines))
        print(f"Exported {image_name} to YOLO Segment format.")
    else:
        print(f"No valid labels to export for {image_name}. Skipping export.")

